ANTHROPIC_API_KEY=sk-ant-...
PORT=3001
NODE_ENV=development

# Allowed CORS origin for API responses.
# Mobile apps bypass CORS, so '*' is fine for a mobile-only backend.
# For production with a web client set this to your domain, e.g.:
# CLIENT_ORIGIN=https://daily60.app
CLIENT_ORIGIN=*

# Static bearer token sent by mobile clients as: Authorization: Bearer <value>
# Protects the backend from unauthorized use (cost drain from API calls).
# Leave empty in development — the guard is skipped when this is unset.
# In production: generate a strong random secret and set the same value in
# mobile's EXPO_PUBLIC_API_SECRET environment variable.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=

# Postgres connection string for AI usage quotas + entitlement storage.
# LEAVE EMPTY to disable quotas entirely (the middleware passes through and the
# backend behaves exactly as before — no DB connection is attempted).
# Set to your Railway Postgres URL to activate per-user daily generation limits.
# e.g. DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# RevenueCat secret API key (server-side entitlement verification).
# Leave empty for now — until set, every user is treated as free tier.
REVENUECAT_API_KEY=
